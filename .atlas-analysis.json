  "keyFeatures": [
    "Single binary deployment with embedded migrations",
    "Server-rendered HTML with no JavaScript frameworks",
    "Posts, comments, threaded replies, and upvoting",
    "User profiles with karma and reputation tracking",
    "Admin panel with user management, roles, and tags",
    "Full-text search and leaderboard",
    "Dark mode support",
    "SEO-optimized with sitemap and robots.txt"
  ],
  "publicApiSurface": [
    "oforum serve - Start the forum server",
    "oforum init - Generate .env configuration interactively",
    "oforum migrate - Run database migrations",
    "oforum seed - Seed database with demo data",
    "oforum version - Print version information",
    "oforum update - Update to latest release",
    "oforum help - Display help information",
    "DATABASE_URL - PostgreSQL connection string (required)",
    "PORT - Server port (default: 8080)"
  ]
}
